# =========================================================
# Configuracion del servidor OpenWA (Juntos por Oriana)
# =========================================================
# Este archivo es cargado por docker-compose.
# AJUSTA LA CONTRASENA DE LA API ANTES DE DESPLEGAR.

# --- API ---
# Puerto del API + Dashboard de OpenWA (Docker lo expone a 127.0.0.1:2785)
PORT=2785

# Nombre de la sesion WhatsApp (aparece en el dashboard)
SESSION_NAME=juntospororiana

# Motor de WhatsApp: whatsapp-web.js (Puppeteer) o baileys (WebSocket)
# Para VPS pequenos se recomienda baileys (sin navegador)
ENGINE_TYPE=baileys

# --- Base de datos ---
# SQLite (por defecto, archivo en ./data/openwa.sqlite)
DB_TYPE=sqlite
DB_PATH=./data/openwa.sqlite

# PostgreSQL (descomenta para usarlo en produccion)
# DB_TYPE=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=jpo
# DB_PASSWORD=cambia_esto
# DB_NAME=JuntosPorOriana

# --- Cache (opcional) ---
# CACHE_TYPE=memory
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- Almacenamiento de medios ---
STORAGE_TYPE=local
MEDIA_PATH=./data/media

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=production

# --- API Key ---
# Por defecto OpenWA genera una API key aleatoria en el primer arranque
# y la guarda en ./data/.api-key. Si quieres fijarla, descomenta:
# INITIAL_API_KEY=owa_k1_cambia_esta_clave_larga_y_aleatoria
# ALLOW_DEV_API_KEY=false

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_SESSION_MGMT=10
RATE_LIMIT_SEND_MESSAGE=60

# --- Webhooks ---
# Si quieres que OpenWA notifique a FastAPI ante eventos (ej. message.received)
# WEBHOOK_URL=http://127.0.0.1:8000/openwa/webhook
# WEBHOOK_SECRET=cambia_este_secreto

# --- Puppeteer (solo si ENGINE_TYPE=whatsapp-web.js) ---
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage
