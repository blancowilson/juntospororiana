# =========================================================
# ⚠️ IMPORTANTE: NO COPIES ESTE ARCHIVO SOBRE UN .env EXISTENTE
# =========================================================
# Si ya tienes un .env con tus credenciales reales, perderias
# SECRET_KEY, FERNET_KEY, DB_PASSWORD y todo lo demas.
#
# Formas seguras de usar este archivo:
#
# 1) Instalacion nueva (no tienes .env todavia):
#       cp .env.example .env
#       nano .env       # edita los valores por defecto
#
# 2) Ya tienes .env y solo quieres anadir variables nuevas:
#       python scripts/sync_env.py
#    Esto agrega SOLO las variables nuevas al final de tu .env,
#    preservando todos tus valores (credenciales, claves, etc.).
#
# 3) Ver que se anadira sin tocar nada:
#       python scripts/sync_env.py --dry-run
# =========================================================

# Configuración de Base de Datos (PostgreSQL)
DB_SERVER=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=JuntosPorOriana

# Credenciales del Panel de Administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=contraseña_admin_aqui

# Secret key para sesiones (captcha, CSRF)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_aleatoria_de_64_caracteres_aqui

# =========================================================
# OpenWA (WhatsApp API Gateway)
# =========================================================
# URL del API de OpenWA (mismo VPS, puerto 2785 por defecto)
OPENWA_BASE_URL=http://127.0.0.1:2785/api

# API key generada por OpenWA en data/.api-key
# Ejecuta: cat openwa/data/.api-key
OPENWA_API_KEY=owa_k1_pega_aqui_la_api_key_de_openwa

# ID de la sesion de WhatsApp vinculada
# Ejecuta: bash openwa/init-session.sh  (lo imprime al final)
OPENWA_SESSION_ID=sess_pega_aqui_el_id_de_sesion

# True para enviar mensajes, False para desactivar (modo desarrollo)
OPENWA_ENABLED=true

# Codigo de pais por defecto para normalizar telefonos
# Venezuela = 58, Colombia = 57, Mexico = 52, etc.
OPENWA_DEFAULT_COUNTRY_CODE=58

# =========================================================
# Cifrado de datos personales (PII)
# =========================================================
# Si se dejan vacias, el script de migracion las genera y las escribe aqui:
#   python scripts/migrate_encrypt_data.py
#
# Para generarlas manualmente:
#   FERNET_KEY=$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
#   SEARCH_HMAC_KEY=$(python -c "import secrets; print(secrets.token_hex(32))")
#
# IMPORTANTE: si pierdes estas claves, NO podras descifrar los datos.
# Haz un backup seguro de este archivo en un lugar cifrado.
#
# NOTA OPERATIVA: si estas claves no estan configuradas, la aplicacion
# arranca y funciona, pero los datos se guardan y muestran EN PLANO
# (y aparece un WARNING en los logs al arrancar). Apenas las configures
# y ejecutes el script de migracion, los datos existentes se cifran.
FERNET_KEY=
SEARCH_HMAC_KEY=
