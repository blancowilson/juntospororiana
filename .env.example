# =============================================
# Juntos por Oriana - Variables de Entorno
# =============================================
# Copia este archivo como ".env" y rellena con los valores reales:
#   cp .env.example .env
# El archivo .env NO debe subirse al repositorio.

# ---------------------------------------------
# Base de datos PostgreSQL
# ---------------------------------------------
DB_SERVER=127.0.0.1
DB_PORT=5432
DB_USER=jpo
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURA
DB_NAME=JuntosPorOriana

# ---------------------------------------------
# Credenciales del panel de administracion
# ---------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_SEGURA
